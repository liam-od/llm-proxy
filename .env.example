# Copy to .env and fill in; pass to the proxy (e.g. `docker run --env-file .env`).
# These are the secrets for the Modal-backed aliases — clients never see them.

VLLM_API_KEY=        # bearer for the pensieve-llm / pensieve-transcribe vLLM endpoints
MODAL_TOKEN_ID=      # Modal auth for the embedder RPC (from `modal token current`)
MODAL_TOKEN_SECRET=

# Optional — require clients to authenticate (see README "Securing a hosted
# deployment"). Unset = open proxy.
# PROXY_MASTER_KEY=
